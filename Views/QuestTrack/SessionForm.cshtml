@model EntregaDispositivosMoveis.ViewModels.SessionFormViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    var primaryClass = Model.CrudAction == "UPDATE" ? "primary-button primary-button-primary" : "primary-button";
}

<section class="screen">
    <div class="status-bar status-bar-light">
        <span>9:41</span>
        <span class="status-indicator"></span>
    </div>

    <header>
        <h1 class="page-title">@Model.PageTitle</h1>
        <p class="page-subtitle">@Model.Subtitle</p>
    </header>

    <form method="post" asp-controller="QuestTrack" asp-action="@Model.FormAction" class="form-grid">
        @Html.AntiForgeryToken()
        @if (Model.Id.HasValue)
        {
            <input asp-for="Id" type="hidden" />
        }

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-field">
            <label class="form-label" asp-for="Subject">Materia</label>
            <input class="form-input" asp-for="Subject" />
            <span asp-validation-for="Subject" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="QuestionsAnswered">Questoes feitas</label>
            <input class="form-input" asp-for="QuestionsAnswered" type="number" min="1" />
            <span asp-validation-for="QuestionsAnswered" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="CorrectAnswers">Acertos</label>
            <input class="form-input" asp-for="CorrectAnswers" type="number" min="0" />
            <span asp-validation-for="CorrectAnswers" class="validation-message"></span>
        </div>

        <div class="form-field">
            <label class="form-label" asp-for="StudyDate">Data do estudo</label>
            <input class="form-input" asp-for="StudyDate" type="date" />
            <span asp-validation-for="StudyDate" class="validation-message"></span>
        </div>

        <div class="button-stack">
            <button type="submit" class="@primaryClass">@Model.PrimaryButtonText</button>
            <a class="secondary-button" asp-controller="QuestTrack" asp-action="@Model.SecondaryButtonRoute">@Model.SecondaryButtonText</a>
        </div>
    </form>

    <div class="home-indicator"></div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
