@model EntregaDispositivosMoveis.ViewModels.DeleteSessionViewModel
@{
    ViewData["Title"] = "Excluir sessao";
}

<section class="screen">
    <div class="status-bar status-bar-light">
        <span>9:41</span>
        <span class="status-indicator"></span>
    </div>

    <header>
        <h1 class="page-title">Excluir sessao</h1>
        <p class="page-subtitle">Confirme antes de remover o registro.</p>
    </header>

    <article class="sheet-card delete-card">
        <div class="alert-icon">!</div>
        <h2 class="delete-title">Deseja excluir esta sessao?</h2>
        <p class="delete-meta">@Model.Session.Subject • @Model.Session.QuestionsAnswered questoes • @Model.Session.CorrectAnswers acertos</p>
    </article>

    <div class="pill-switch">
        <a class="secondary-button" asp-controller="QuestTrack" asp-action="History">Cancelar</a>
        <form method="post" asp-controller="QuestTrack" asp-action="DeleteConfirmed">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="danger-button">Excluir</button>
        </form>
    </div>

    <div class="home-indicator"></div>
</section>
